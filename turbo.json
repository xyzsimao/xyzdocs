{
  "$schema": "https://turbo.build/schema.json",

  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".output",
        "public/registry",
        "public/r",
        ".contentlayer/**",
        ".source/**",
        "!.contentlayer/.cache/**",
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "out",
        "build",
        ".vercel"
      ]
    },
    "lint": {},
    "types:check": {
      "dependsOn": [],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "start": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
